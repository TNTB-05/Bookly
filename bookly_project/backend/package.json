{
    "name": "nodejs-template-2025",
    "version": "1.0.0",
    "description": "Template project",
    "main": "server.js",
    "scripts": {
        "test": "jest --coverage",
        "test:watch": "jest --watch",
        "start": "node server.js",
        "db:up": "cd .. && docker-compose up -d db",
        "myadmin:up": "cd .. && docker-compose up -d phpmyadmin",
        "db:reset-win": "cd .. && docker-compose down && docker volume rm bookly_project_db_data || echo Volume already removed && docker-compose up -d",
        "db:reset-mac": "cd .. && docker-compose down && docker volume rm bookly_project_db_data 2>/dev/null; docker-compose up -d && sleep 10 && echo 'Database reset complete!'",
        "db:restart": "cd .. && docker-compose restart db",
        "dev": "npm run db:up && nodemon"
    },
    "author": "Tokaji-Nagy Bence, Varga Bototnd",
    "license": "ISC",
    "devDependencies": {
        "jest": "^30.2.0",
        "nodemon": "^3.1.10",
        "supertest": "^7.2.2"
    },
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^5.1.0",
        "express-session": "^1.18.2",
        "jsonwebtoken": "^9.0.3",
        "multer": "^2.0.2",
        "mysql2": "^3.15.2",
        "nodemailer": "^8.0.1",
        "sharp": "^0.33.2",
        "socket.io": "^4.8.3"
    }
}
