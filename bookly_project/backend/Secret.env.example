# Másold át Secret.env néven a backend/ mappába és töltsd ki saját értékekkel.
# FIGYELEM: a JWT és session titkokat MINDIG hosszú, véletlenszerű stringre cseréld
# (pl. `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`).
# A fájl gitignore-olt, soha ne commitold!

# --- JWT / session titkok ---
JWT_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
SESSION_SECRET=replace-with-session-secret

# --- Szerver ---
PORT=3000
IP_ADDRESS=127.0.0.1
FRONTEND_URL=http://127.0.0.1:5173

# --- Adatbázis (egyezzen a bookly_project/.env-ben megadottakkal) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=bookly_db

# --- Email értesítések (Gmail App Password ajánlott) ---
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Bookly <noreply@example.com>"
